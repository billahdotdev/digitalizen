# ============================================================
# .env.example — Digitalizen
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to git.
# ============================================================

# ── Analytics IDs — replace in index.html ────────────────
# GTM_ID=GTM-XXXXXXX
# META_PIXEL_ID=XXXXXXXXXXXXXXXXXX
# TT_PIXEL_ID=XXXXXXXXXXXXXXXXXX

# ── Meta Conversions API (for Cloudflare Worker) ─────────
# Set these via: wrangler secret put META_PIXEL_ID
# Set these via: wrangler secret put CAPI_ACCESS_TOKEN
# META_PIXEL_ID=
# CAPI_ACCESS_TOKEN=

# ── TikTok Events API (for Cloudflare Worker) ────────────
# Set via: wrangler secret put TT_PIXEL_ID
# Set via: wrangler secret put TT_ACCESS_TOKEN
# TT_PIXEL_ID=
# TT_ACCESS_TOKEN=

# ── Allowed CORS origin ───────────────────────────────────
# ALLOWED_ORIGIN=https://digitalizen.billah.dev
